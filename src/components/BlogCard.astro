---
import { Calendar, Clock, ArrowUpRight } from "lucide-react";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  readTime: string;
}

const { title, description, date, tags, slug, readTime } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a
  href={`/blog/${slug}`}
  class="group flex flex-col rounded-xl border border-border bg-surface p-6 transition-all duration-300 hover:-translate-y-1 hover:border-border-hover hover:shadow-lg hover:shadow-accent-glow/50"
>
  <!-- Tags -->
  <div class="mb-3 flex flex-wrap gap-1.5">
    {
      tags.slice(0, 3).map((tag) => (
        <span class="rounded-md bg-accent-subtle px-2 py-0.5 text-xs font-medium text-accent-hover">
          {tag}
        </span>
      ))
    }
  </div>

  <!-- Title -->
  <h3
    class="mb-2 text-lg font-semibold text-text-primary transition-colors duration-150 group-hover:text-accent-hover"
  >
    <span class="inline-flex items-center gap-1">
      {title}
      <ArrowUpRight
        className="h-4 w-4 opacity-0 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
      />
    </span>
  </h3>

  <!-- Description -->
  <p class="mb-4 flex-1 text-sm leading-relaxed text-text-secondary">
    {description}
  </p>

  <!-- Meta -->
  <div class="flex items-center gap-3 text-xs text-text-tertiary">
    <span class="inline-flex items-center gap-1">
      <Calendar className="h-3.5 w-3.5" />
      {formattedDate}
    </span>
    <span class="inline-flex items-center gap-1">
      <Clock className="h-3.5 w-3.5" />
      {readTime}
    </span>
  </div>
</a>
